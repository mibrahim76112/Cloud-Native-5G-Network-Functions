tee /workspace/.gitignore << 'EOF'
# Build output
build/
cmake-build-*/

# Generated protobuf/gRPC files
proto_gen/

# Compiled binaries
*.o
*.a
*.so
*.out

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt

# VSCode
.vscode/

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db

# Kubernetes
*.kubeconfig

# Logs
*.log

# gRPC generated (in case generated outside build dir)
*.pb.cc
*.pb.h
*.grpc.pb.cc
*.grpc.pb.h
EOF